  "components": {
    "schemas": {
      "CompanyListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/CompanyRankingItemSchema"
            },
            "type": "array",
            "title": "Items",
            "description": "\u4f01\u696d\u30e9\u30f3\u30ad\u30f3\u30b0\u4e00\u89a7"
          },
          "total": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Total",
            "description": "\u7dcf\u4ef6\u6570"
          },
          "page": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Page",
            "description": "\u73fe\u5728\u30da\u30fc\u30b8\u756a\u53f7\uff081\u59cb\u307e\u308a\uff09"
          },
          "page_size": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Page Size",
            "description": "1\u30da\u30fc\u30b8\u3042\u305f\u308a\u306e\u4ef6\u6570"
          }
        },
        "type": "object",
        "required": [
          "total",
          "page",
          "page_size"
        ],
        "title": "CompanyListResponse",
        "description": "\u4f01\u696d\u30e9\u30f3\u30ad\u30f3\u30b0\u4e00\u89a7\u30ec\u30b9\u30dd\u30f3\u30b9\uff08\u30da\u30fc\u30b8\u30cd\u30fc\u30b7\u30e7\u30f3\u4ed8\u304d\uff09."
      },
      "CompanyRankingItemSchema": {
        "properties": {
          "company_id": {
            "type": "string",
            "format": "uuid",
            "title": "Company Id",
            "description": "\u4f01\u696dID"
          },
          "securities_code": {
            "type": "string",
            "maxLength": 10,
            "minLength": 1,
            "title": "Securities Code",
            "description": "\u8a3c\u5238\u30b3\u30fc\u30c9"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "description": "\u4f01\u696d\u540d"
          },
          "industry": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Industry",
            "description": "\u696d\u7a2e"
          },
          "market_cap": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Market Cap",
            "description": "\u6642\u4fa1\u7dcf\u984d\uff08\u5104\u5186\uff09"
          },
          "total_score": {
            "type": "number",
            "minimum": 0.0,
            "title": "Total Score",
            "description": "\u7d71\u5408\u7dcf\u5408\u30b9\u30b3\u30a2"
          },
          "structure_score": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Structure Score",
            "description": "\u69cb\u9020\u30b9\u30b3\u30a2\uff080\u2013100\uff09"
          },
          "event_score": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Event Score",
            "description": "\u30a4\u30d9\u30f3\u30c8\u30b9\u30b3\u30a2\uff080\u2013100\uff09"
          },
          "event_boost": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 2.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Event Boost",
            "description": "\u30a4\u30d9\u30f3\u30c8\u30d6\u30fc\u30b9\u30c8\u4fc2\u6570"
          },
          "confidence": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ConfidenceLevelEnum"
              }
            ],
            "description": "\u4fe1\u983c\u5ea6\u30ec\u30d9\u30eb"
          },
          "unrealized_gain": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Unrealized Gain",
            "description": "\u542b\u307f\u76ca\uff08\u5104\u5186\uff09"
          },
          "has_event": {
            "type": "boolean",
            "title": "Has Event",
            "description": "\u30a4\u30d9\u30f3\u30c8\u30b7\u30b0\u30ca\u30eb\u304c1\u4ef6\u4ee5\u4e0a\u3042\u308b\u304b"
          }
        },
        "type": "object",
        "required": [
          "company_id",
          "securities_code",
          "name",
          "industry",
          "total_score",
          "structure_score",
          "event_score",
          "confidence",
          "has_event"
        ],
        "title": "CompanyRankingItemSchema",
        "description": "\u4f01\u696d\u30e9\u30f3\u30ad\u30f3\u30b0\u4e00\u89a7\u306e1\u30a8\u30f3\u30c8\u30ea."
      },
      "ConfidenceLevelEnum": {
        "type": "string",
        "enum": [
          "high",
          "mid",
          "low"
        ],
        "title": "ConfidenceLevelEnum",
        "description": "\u7d71\u5408\u30b9\u30b3\u30a2\u306e\u4fe1\u983c\u5ea6\u30ec\u30d9\u30eb."
      },
      "DashboardKpiResponse": {
        "properties": {
          "total_companies": {
            "type": "integer",
            "title": "Total Companies"
          },
          "high_score_companies": {
            "type": "integer",
            "title": "High Score Companies"
          },
          "avg_score": {
            "type": "number",
            "title": "Avg Score"
          },
          "event_count": {
            "type": "integer",
            "title": "Event Count"
          }
        },
        "type": "object",
        "required": [
          "total_companies",
          "high_score_companies",
          "avg_score",
          "event_count"
        ],
        "title": "DashboardKpiResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "login_email": {
            "type": "string",
            "format": "email",
            "title": "Login Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "login_email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "MeResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "login_email": {
            "type": "string",
            "title": "Login Email"
          },
          "role": {
            "type": "string",
            "title": "Role"
          }
        },
        "type": "object",
        "required": [
          "id",
          "login_email",
          "role"
