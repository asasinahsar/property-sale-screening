# Application
APP_NAME=Property Sale Screening API
DEBUG=True

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/property_db

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# JWT + HttpOnly Cookie
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_NAME=access_token
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
